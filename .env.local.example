# Plantilla. Copia este archivo a .env.local y pega ahí tus llaves REALES:
#   cp .env.local.example .env.local
# .env.local está en .gitignore y nunca se sube. Este example solo lleva placeholders.

# ---- Clerk (autenticación / identidad) ----
# Dashboard Clerk > Configure > API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---- Supabase (base de datos / Postgres) ----  [se usa desde la Fase 1]
# Dashboard Supabase > Project Settings > API.
# Formato de llaves nuevo: publishable (cliente) y secret (solo servidor).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Secret: SOLO en servidor / MCP. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# Password de Postgres (migraciones / conexión directa / MCP).
SUPABASE_DB_PASSWORD=xxx

# ---- Anthropic (chat IA in-app) ----  [se usa desde la Fase 2]
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Google Calendar (reuniones por proyecto) ----
# Google Cloud Console > APIs & Services > Credentials > OAuth client (Web).
# Redirect URI autorizado: http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
